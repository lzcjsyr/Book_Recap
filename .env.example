# ============================================
# 智能视频制作系统 - 环境变量配置文件
# ============================================

# OpenRouter API密钥 - 用于LLM文本生成（推荐）
# 获取地址: https://openrouter.ai/
# 推荐模型: google/gemini-2.5-pro
OPENROUTER_API_KEY=你的OpenRouter_API密钥

# SiliconFlow API密钥 - 国内LLM服务商（备选）
# 获取地址: https://siliconflow.cn/
# Base URL: https://api.siliconflow.cn/v1/
# 支持模型: GLM-4.6, Kimi-K2-Instruct, Qwen3等
SILICONFLOW_KEY=你的SiliconFlow密钥

# 火山方舟API密钥 - 用于豆包图像生成（必需）
# 获取地址: https://console.volcengine.com/ark
# 推荐模型: : Seedream 4.0
SEEDREAM_API_KEY=你的火山引擎方舟API密钥

# 字节语音合成大模型配置 - 用于高质量TTS语音合成（必需）
# 获取地址: https://console.volcengine.com/
# 支持音色: zh_male_yuanboxiaoshu_moon_bigtts (默认可用)
BYTEDANCE_TTS_APPID=你的字节TTS_APPID
BYTEDANCE_TTS_ACCESS_TOKEN=你的字节TTS_ACCESS_TOKEN

# ============================================
# 【重要说明】根据你的使用配置，需要的最小API密钥组合：
# ============================================

# 方案1: 推荐配置（最佳体验）
# OPENROUTER_API_KEY + SEEDREAM_API_KEY + BYTEDANCE_TTS_*
# - LLM: OpenRouter (Gemini 2.5 Pro)
# - 图像: 豆包 Seedream 4.0  
# - 语音: 字节语音合成大模型

# 方案2: 国内服务配置
# SILICONFLOW_KEY + SEEDREAM_API_KEY + BYTEDANCE_TTS_*
# - LLM: SiliconFlow (GLM-4.6)
# - 图像: 豆包 Seedream 4.0
# - 语音: 字节语音合成大模型