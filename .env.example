# ============================================
# 智能视频制作系统 - 环境变量示例
# 复制为 .env 后填入真实值；.env 已被 .gitignore 忽略。
# ============================================

# 步骤1/步骤2 LLM 使用的密钥；当前 config.py 默认读取 SILICONFLOW_KEY。
SILICONFLOW_KEY=你的SiliconFlow密钥

# 可选 LLM 服务商。
OPENROUTER_API_KEY=你的OpenRouter_API密钥
# 步骤1 Claude Agent SDK（小米 MiMo Anthropic 端点）必需
MIMO_API_KEY=你的MIMO_API密钥

# 图像生成服务。当前默认 image_server=doubao 时需要 SEEDREAM_API_KEY；
# image_server=google 时需要 GOOGLE_CLOUD_API_KEY。
SEEDREAM_API_KEY=你的火山引擎方舟API密钥
GOOGLE_CLOUD_API_KEY=你的Google_API密钥

# 字节语音合成大模型。当前代码使用新版 API Key 鉴权。
BYTEDANCE_TTS_API_KEY=你的字节TTS_API_KEY
BYTEDANCE_TTS_VOICE_ID=你的声音ID
BYTEDANCE_TTS_VERIFY_SSL=true

# MinerU PDF 精准解析。仅复杂表格/研报类 PDF 抽取时需要。
MINERU_API_TOKEN=你的MinerU_API_TOKEN
